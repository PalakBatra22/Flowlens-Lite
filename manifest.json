{
  "manifest_version": 3,
  "name": "FlowLens Lite",
  "version": "1.0",
  "description": "Detects bottlenecks in GitHub PRs and Jira issues locally in the browser.",
  "permissions": ["storage"],
  "host_permissions": [
    "*://github.com/*",
    "*://*/browse/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://github.com/*/pull/*",
        "*://*/browse/*"
      ],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "FlowLens Lite"
  }
}
